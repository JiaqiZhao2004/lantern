tunnel: __TUNNEL_ID__
credentials-file: __CREDENTIALS_FILE__

ingress:
  - hostname: __BACKEND_PUBLIC_HOSTNAME__
    # Keep this aligned with NGINX_BIND_PORT in ../app-runtime/compose.env and with
    # the loopback validation commands in ../reverse-proxy/README.md and this
    # component README if you change the local origin port.
    service: __LOCAL_ORIGIN__
  - service: http_status:404
