AWS_SHARED_CREDENTIALS_PATH=/srv/lantern/secrets/aws-credentials

BACKEND_IMAGE=ghcr.io/jiaqizhao2004/lantern-backend:replace-with-commit-sha
FIREBASE_ADMIN_CREDENTIALS_PATH=/srv/lantern/secrets/firebase-adminsdk.json
NGINX_BIND_PORT=8080
SYNC_RUNNER_HEARTBEAT_MAX_AGE_SECONDS=60
BACKEND_SHARED_NETWORK=lantern-backend

# Optional: set both values when BACKEND_IMAGE points at a private GHCR image.
# GHCR_TOKEN should be a GitHub personal access token with read:packages.
GITHUB_USERNAME=
GHCR_TOKEN=
