COMPOSE_PROJECT_NAME=lantern-public
APP_STACK_ENV_DIR=./env/public
POSTGRES_VOLUME_NAME=lantern-public-postgres-data

AWS_SHARED_CREDENTIALS_PATH=/srv/lantern-public/secrets/aws-credentials
FIREBASE_ADMIN_CREDENTIALS_PATH=/srv/lantern-public/secrets/firebase-adminsdk.json

BACKEND_IMAGE=ghcr.io/jiaqizhao2004/lantern-backend:replace-with-commit-sha

NGINX_BIND_PORT=8081
OBSERVABILITY_STACK_LABEL=public
SYNC_RUNNER_HEARTBEAT_MAX_AGE_SECONDS=60
BACKEND_SHARED_NETWORK=lantern-backend

# Shared with ops/observability/backend/compose.yml node_exporter textfile collector.
OBSERVABILITY_TEXTFILE_COLLECTOR_PATH=/srv/lantern/ops/observability/backend/textfile_collector
