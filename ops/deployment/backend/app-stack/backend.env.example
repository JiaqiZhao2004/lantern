# AWS app dependencies
AWS_REGION=us-east-2
AWS_PROFILE=lantern-app-kms
KMS_KEY_ID=alias/lantern/backend-app

# App runtime
DATABASE_URL=postgresql+psycopg://lantern_app:replace-me@db:5432/lantern
AUTH_MODE=restricted
AUTHORIZED_EMAILS=roy@example.com,approved-user@example.com
ACCESS_CONTACT=Roy Zhao
PLAID_ENV=sandbox
PLAID_CLIENT_ID=replace-me
PLAID_SECRET=replace-me
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Some banks redirect the user out to the bank’s site/app to authenticate, then send them back to your app. PLAID_REDIRECT_URI is the URL Plaid/bank should return the browser to after that flow.
PLAID_REDIRECT_URI=https://lantern.royzhao.dev/
# Plaid webhooks should use the public same-origin API route after CloudFront
# /api/* routing is live. Do not point Plaid at the protected backend origin.
PLAID_WEBHOOK_URL=https://lantern.royzhao.dev/api/v1/plaid/webhooks

# Backend integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Logging / worker behavior
LOG_LEVEL=INFO
SYNC_RUNNER_SLEEP_SECONDS=10
