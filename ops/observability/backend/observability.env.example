# Shared with the backend app stack.
BACKEND_SHARED_NETWORK=lantern-backend

# Loopback-only UI ports.
PROMETHEUS_BIND_PORT=9090
ALERTMANAGER_BIND_PORT=9093
GRAFANA_BIND_PORT=3001

# Grafana local admin bootstrap.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace-me
GF_USERS_ALLOW_SIGN_UP=false

# Postgres exporter. Use the dedicated monitoring role, not app credentials.
DATA_SOURCE_NAME=postgresql://lantern_monitor:replace-me@db:5432/lantern?sslmode=disable

# Alertmanager SMTP settings. Keep real values only in observability.env on the host.
SMTP_SMARTHOST=smtp.example.com:587
SMTP_FROM=lantern-alerts@example.com
SMTP_USERNAME=lantern-alerts@example.com
SMTP_PASSWORD=replace-me
SMTP_REQUIRE_TLS=true
ALERT_EMAIL_TO=you@example.com
