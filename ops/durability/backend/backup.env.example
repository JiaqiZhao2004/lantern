# Optional host-side backup upload settings for backup-db.sh.
# This file stays on the server and is separate from Docker Compose.

# AWS region that owns the durability bucket.
BACKUP_AWS_REGION=us-east-2

# Dedicated AWS CLI profile that stores the Terraform-created backup-upload key.
BACKUP_AWS_PROFILE=lantern-backup-upload

# Primary upload target for deploy-time and scheduled short-retention backups.
BACKUP_S3_BUCKET=lantern-db-backups
BACKUP_S3_PREFIX=postgres/six-hourly

# Weekly retention is modeled as a second prefix in the same bucket.
# Leave weekly copies disabled for ordinary deploys.
BACKUP_S3_WEEKLY_PREFIX=postgres/weekly
BACKUP_S3_UPLOAD_WEEKLY_COPY=0

# Remove local backup files older than this many days after a successful run.
BACKUP_LOCAL_RETENTION_DAYS=7

# Optional Prometheus textfile collector directory for backup freshness metrics.
# Use the absolute path to ops/observability/backend/textfile_collector on the host.
BACKUP_PROM_TEXTFILE_DIR=/srv/lantern/ops/observability/backend/textfile_collector
